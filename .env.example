# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your keys. Never commit .env.local.
# ---------------------------------------------------------------------------

# REQUIRED — OpenAI key used for Whisper transcription (app/api/transcribe/route.ts)
OPENAI_API_KEY=sk-your-openai-key-here

# REQUIRED — Anthropic key used for speaker identification, summary and
# action-item extraction (app/api/analyze/route.ts, app/api/regenerate/route.ts)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional overrides
# Transcription model. whisper-1 returns verbose_json with per-segment
# confidence, which this app relies on.
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# LLM used for analysis. Any recent Claude model id your account can access.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional — dedicated acoustic diarisation provider (better speaker
# separation than LLM-only attribution). See the comments in
# app/api/transcribe/route.ts for where to plug it in.
# ASSEMBLYAI_API_KEY=
